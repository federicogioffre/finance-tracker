# ============================================================
# LandHunter - Variabili d'Ambiente
# ============================================================
# Copia questo file come .env e inserisci i tuoi valori reali:
#   cp .env.example .env
# ============================================================

# --- Gemini API (Analisi Semantica LLM) ---
# Ottieni la tua API key da: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=la-tua-api-key-gemini

# --- Telegram Bot (Notifiche Deal) ---
# 1. Apri Telegram e cerca @BotFather
# 2. Invia /newbot e segui le istruzioni per creare il bot
# 3. BotFather ti dara' il token (es. 123456789:ABCdefGHIjklMNO...)
TELEGRAM_BOT_TOKEN=il-tuo-bot-token

# 4. Per ottenere il CHAT_ID:
#    a. Avvia il tuo bot su Telegram (clicca Start)
#    b. Invia un messaggio qualsiasi al bot
#    c. Apri nel browser: https://api.telegram.org/bot<TOKEN>/getUpdates
#    d. Cerca "chat":{"id":XXXXXXX} - quel numero e' il tuo CHAT_ID
#    Oppure per un gruppo, aggiungi il bot al gruppo e ripeti dal punto (b)
TELEGRAM_CHAT_ID=il-tuo-chat-id
