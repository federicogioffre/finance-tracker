# PostgreSQL
DATABASE_URL=postgresql+asyncpg://hedgefund:hedgefund@postgres:5432/hedgefund

# Redis
REDIS_URL=redis://redis:6379/0

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# API
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60

# External APIs (optional)
ALPHA_VANTAGE_API_KEY=
NEWS_API_KEY=
FINNHUB_API_KEY=

# Logging
LOG_LEVEL=INFO
